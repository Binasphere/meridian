# --- Database -------------------------------------------------------------
# Port 5433 avoids colliding with a Postgres you may already run on 5432.
DATABASE_URL="postgresql://meridian:meridian@localhost:5433/meridian?schema=public"

# --- Auth -----------------------------------------------------------------
# Sessions are JWTs signed with this key. Generate a fresh one per environment:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
AUTH_SECRET="dev-only-secret-please-generate-a-real-one-before-deploying"

# --- Runtime --------------------------------------------------------------
PORT=3000
NODE_ENV=development

# --- Supabase (backend) ---------------------------------------------------
# The app runs on its client-side simulation until these are set; once present,
# features migrate onto Supabase. Both are safe to expose to the browser — only
# the anon/publishable key goes here, never the service-role key. Find them in
# your Supabase project under Settings → API.
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"

# --- Price oracle ---------------------------------------------------------
# "simulated" runs the built-in server-authoritative price engine (no network,
# no API keys). The PriceOracle interface is the seam where a real market-data
# provider drops in — see src/server/oracle/types.ts.
PRICE_ORACLE=simulated

# Fixes the simulated feed's PRNG so a run is reproducible (useful for tests
# and demos). Leave unset for a fresh random walk on every boot.
# ORACLE_SEED=42
